IMPORT debug.spy

FUNC menu {
PRINT YELLOW "=== SpyLang Starter Menu ==="
PRINT "1: Stress Test"
PRINT RED "2: Coming soon"
PRINT RED "3: Coming soon"
PRINT RED "4: Coming soon"
PRINT BLUE "5: EXIT"
INPUT option
IF option == 1 {
CALL debug
}
ELSEIF option == 5 {
EXIT
}
}

CALL menu