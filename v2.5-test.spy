# SpyLang v2.5 debug test
# Tests the new v2.5 game framework features.
# Run:
# py spy.py debug_v2_5.spy

FUNC pass name {
    GLOBAL passed
    LET passed = passed + 1
    PRINT GREEN "[PASS]"
    PRINT %name%
}

FUNC fail name {
    GLOBAL failed
    LET failed = failed + 1
    PRINT RED "[FAIL]"
    PRINT %name%
}

FUNC debug {
    GLOBAL passed failed

    CLS
    PRINT GREEN "=============================="
    PRINT GREEN " SPYLANG v2.5 DEBUG TEST"
    PRINT GREEN "=============================="
    VERSION

    LET passed = 0
    LET failed = 0

    PRINT ""
    PRINT YELLOW "1) NESTED OBJECTS"

    LET player = {name:"Agent",stats:{hp:100,level:1},gold:50}

    IF player.stats.hp == 100 {
        CALL pass "Nested_object_read_player_stats_hp"
    }
    ELSE {
        CALL fail "Nested_object_read_player_stats_hp"
    }

    SET player.stats.hp 75

    IF player.stats.hp == 75 {
        CALL pass "Nested_object_SET_SET_player_stats_hp_75"
    }
    ELSE {
        CALL fail "Nested_object_SET"
    }

    SET player.stats.level 2

    IF player.stats.level == 2 {
        CALL pass "Nested_object_SET_level"
    }
    ELSE {
        CALL fail "Nested_object_SET_level"
    }

    PRINT ""
    PRINT YELLOW "2) SAVE SLOT MENU"

    SAVESLOT debug_player player
    SLOTMENU slot_menu
    LET slot_count = LEN slot_menu

    IF slot_count > 0 {
        CALL pass "SLOTMENU"
    }
    ELSE {
        CALL fail "SLOTMENU"
    }

    PRINT ""
    PRINT YELLOW "3) ACCOUNT SYSTEM"

    ACCOUNTDELETE debug_user deleted_old
    ACCOUNTCREATE debug_user pass123 created_account
    ACCOUNTLOGIN debug_user pass123 login_ok

    IF login_ok == true {
        CALL pass "ACCOUNTCREATE_ACCOUNTLOGIN"
    }
    ELSE {
        CALL fail "ACCOUNTCREATE_ACCOUNTLOGIN"
    }

    ACCOUNTSET debug_user score 999
    ACCOUNTGET debug_user score account_score

    IF account_score == 999 {
        CALL pass "ACCOUNTSET_ACCOUNTGET"
    }
    ELSE {
        CALL fail "ACCOUNTSET_ACCOUNTGET"
    }

    ACCOUNTLIST account_list
    LET account_count = LEN account_list

    IF account_count > 0 {
        CALL pass "ACCOUNTLIST"
    }
    ELSE {
        CALL fail "ACCOUNTLIST"
    }

    PRINT ""
    PRINT YELLOW "4) SMARTER OFFLINE AI"

    AIPRESET aggressive aggressive_move

    IF aggressive_move CONTAINS "" {
        CALL pass "AIPRESET_aggressive"
    }
    ELSE {
        CALL fail "AIPRESET_aggressive"
    }

    AIPRESET boss boss_move

    IF boss_move CONTAINS "" {
        CALL pass "AIPRESET_boss"
    }
    ELSE {
        CALL fail "AIPRESET_boss"
    }

    AIPATROL [left,right] guard_path patrol_one
    AIPATROL [left,right] guard_path patrol_two

    IF patrol_one != patrol_two {
        CALL pass "AIPATROL_changes_direction"
    }
    ELSE {
        CALL fail "AIPATROL_changes_direction"
    }

    AICHASE 1 1 4 1 chase_dir

    IF chase_dir == "right" {
        CALL pass "AICHASE"
    }
    ELSE {
        CALL fail "AICHASE"
    }

    AIFLEE 1 1 4 1 flee_dir

    IF flee_dir == "left" {
        CALL pass "AIFLEE"
    }
    ELSE {
        CALL fail "AIFLEE"
    }

    PRINT ""
    PRINT YELLOW "5) MAP TRANSITIONS"

    LET map_one = [
"#####",
"#P..#",
"#####"
]

    LET map_two = [
"#####",
"#..P#",
"#####"
]

    MAPTRANS 3 1 3 1 map_two 1 1 current_map new_x new_y

    IF mapchanged == true {
        CALL pass "MAPTRANS_changed_map"
    }
    ELSE {
        CALL fail "MAPTRANS_changed_map"
    }

    IF new_x == 1 {
        CALL pass "MAPTRANS_new_x"
    }
    ELSE {
        CALL fail "MAPTRANS_new_x"
    }

    IF new_y == 1 {
        CALL pass "MAPTRANS_new_y"
    }
    ELSE {
        CALL fail "MAPTRANS_new_y"
    }

    PRINT ""
    PRINT YELLOW "6) QUEST SYSTEM"

    QUESTADD main "Find the debug key"
    QUESTSTATUS main quest_before

    IF quest_before == false {
        CALL pass "QUESTADD_QUESTSTATUS_open"
    }
    ELSE {
        CALL fail "QUESTADD_QUESTSTATUS_open"
    }

    QUESTDONE main
    QUESTSTATUS main quest_after

    IF quest_after == true {
        CALL pass "QUESTDONE"
    }
    ELSE {
        CALL fail "QUESTDONE"
    }

    QUESTLIST quests
    LET quest_count = LEN quests

    IF quest_count > 0 {
        CALL pass "QUESTLIST"
    }
    ELSE {
        CALL fail "QUESTLIST"
    }

    PRINT ""
    PRINT YELLOW "7) XP / LEVEL SYSTEM"

    LET xp = 0
    LET level = 1

    XPADD xp level 250 leveled

    IF level == 2 {
        CALL pass "XPADD_level_up"
    }
    ELSE {
        CALL fail "XPADD_level_up"
    }

    IF leveled == true {
        CALL pass "XPADD_leveled_variable"
    }
    ELSE {
        CALL fail "XPADD_leveled_variable"
    }

    LEVELINFO xp level needed

    IF needed >= 0 {
        CALL pass "LEVELINFO"
    }
    ELSE {
        CALL fail "LEVELINFO"
    }

    PRINT ""
    PRINT YELLOW "8) SHOP SYSTEM"

    LET gold = 50
    LET shop_inventory = []

    SHOPBUY gold 20 "Potion" shop_inventory bought

    IF bought == true {
        CALL pass "SHOPBUY_bought"
    }
    ELSE {
        CALL fail "SHOPBUY_bought"
    }

    IF gold == 30 {
        CALL pass "SHOPBUY_gold_removed"
    }
    ELSE {
        CALL fail "SHOPBUY_gold_removed"
    }

    HASITEM shop_inventory "Potion" has_potion

    IF has_potion == true {
        CALL pass "SHOPBUY_item_added"
    }
    ELSE {
        CALL fail "SHOPBUY_item_added"
    }

    SHOPSELL shop_inventory "Potion" 10 gold sold

    IF sold == true {
        CALL pass "SHOPSELL_sold"
    }
    ELSE {
        CALL fail "SHOPSELL_sold"
    }

    IF gold == 40 {
        CALL pass "SHOPSELL_gold_added"
    }
    ELSE {
        CALL fail "SHOPSELL_gold_added"
    }

    PRINT ""
    PRINT YELLOW "9) ENEMY ENTITY SYSTEM"

    ENEMYNEW Goblin 40 7 1 1 enemy

    IF enemy.name == "Goblin" {
        CALL pass "ENEMYNEW_name"
    }
    ELSE {
        CALL fail "ENEMYNEW_name"
    }

    IF enemy.hp == 40 {
        CALL pass "ENEMYNEW_hp"
    }
    ELSE {
        CALL fail "ENEMYNEW_hp"
    }

    ENEMYHIT enemy 15 enemy_dead

    IF enemy.hp == 25 {
        CALL pass "ENEMYHIT_damage"
    }
    ELSE {
        CALL fail "ENEMYHIT_damage"
    }

    ENEMYALIVE enemy enemy_alive

    IF enemy_alive == true {
        CALL pass "ENEMYALIVE"
    }
    ELSE {
        CALL fail "ENEMYALIVE"
    }

    LET target_hp = 100
    ENEMYATTACK enemy target_hp damage_done

    IF damage_done == 7 {
        CALL pass "ENEMYATTACK_damage_variable"
    }
    ELSE {
        CALL fail "ENEMYATTACK_damage_variable"
    }

    IF target_hp == 93 {
        CALL pass "ENEMYATTACK_lowers_HP"
    }
    ELSE {
        CALL fail "ENEMYATTACK_lowers_HP"
    }

    LET battle_map = [
"#####",
"#...#",
"#...#",
"#####"
]

    ENEMYMOVE enemy battle_map "d" enemy_moved

    IF enemy_moved == true {
        CALL pass "ENEMYMOVE"
    }
    ELSE {
        CALL fail "ENEMYMOVE"
    }

    IF enemy.x == 2 {
        CALL pass "ENEMYMOVE_x_update"
    }
    ELSE {
        CALL fail "ENEMYMOVE_x_update"
    }

    PRINT ""
    PRINT YELLOW "10) MULTIPLAYER HELPERS"

    LOBBYADD Lennart
    LOBBYADD Friend
    LOBBYLIST lobby
    LET lobby_count = LEN lobby

    IF lobby_count == 2 {
        CALL pass "LOBBYADD_LOBBYLIST"
    }
    ELSE {
        CALL fail "LOBBYADD_LOBBYLIST"
    }

    TURNINIT lobby current_turn

    IF current_turn == "Lennart" {
        CALL pass "TURNINIT"
    }
    ELSE {
        CALL fail "TURNINIT"
    }

    ISTURN Lennart is_lennart

    IF is_lennart == true {
        CALL pass "ISTURN"
    }
    ELSE {
        CALL fail "ISTURN"
    }

    NEXTTURN current_turn

    IF current_turn == "Friend" {
        CALL pass "NEXTTURN"
    }
    ELSE {
        CALL fail "NEXTTURN"
    }

    SETUSERNAME "Tester"
    CHATSEND "hello from debug"
    CHATRECEIVE chat_message
    NETREADY net_ready

    IF net_ready == false {
        CALL pass "NETREADY_false_without_connection"
    }
    ELSE {
        CALL pass "NETREADY_true_with_connection"
    }

    NETINFO

    PRINT ""
    PRINT GREEN "=============================="
    PRINT GREEN " DEBUG RESULT"
    PRINT GREEN "=============================="

    PRINT "Passed:"
    PRINT %passed%

    PRINT "Failed:"
    PRINT %failed%

    IF failed == 0 {
        PRINT GREEN "ALL V2.5 TESTS PASSED"
    }
    ELSE {
        PRINT RED "SOME V2.5 TESTS FAILED"
    }
}

CALL debug
