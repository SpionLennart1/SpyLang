# SpyLang v3.0 test file
# Tests the real v3 additions:
# - Better syntax/runtime safety should let this run cleanly
# - Map engine tools
# - Menu system
# - Event system

FUNC pass name {
    GLOBAL passed
    LET passed = passed + 1
    PRINT GREEN "[PASS]"
    PRINT %name%
}

FUNC fail name {
    GLOBAL failed
    LET failed = failed + 1
    PRINT RED "[FAIL]"
    PRINT %name%
}

FUNC mark_boss {
    GLOBAL boss_mark
    LET boss_mark = 1
}

FUNC main {
    GLOBAL passed failed boss_mark

    CLS
    PRINT GREEN "=============================="
    PRINT GREEN " SPYLANG V3.0 TEST"
    PRINT GREEN "=============================="
    VERSION

    LET passed = 0
    LET failed = 0
    LET boss_mark = 0

    PRINT ""
    PRINT YELLOW "1) MAP ENGINE"

    MAPFILL 8 5 "." map
    MAPSIZE map map_w map_h

    IF map_w == 8 {
        CALL pass MAPFILL_width
    }
    ELSE {
        CALL fail MAPFILL_width
    }

    IF map_h == 5 {
        CALL pass MAPFILL_height
    }
    ELSE {
        CALL fail MAPFILL_height
    }

    MAPBORDER map "#"
    MAPCOUNT map "#" border_count

    IF border_count == 22 {
        CALL pass MAPBORDER
    }
    ELSE {
        CALL fail MAPBORDER
    }

    MAPRECT map 2 2 3 1 "X"
    MAPCOUNT map "X" rect_count

    IF rect_count == 3 {
        CALL pass MAPRECT
    }
    ELSE {
        CALL fail MAPRECT
    }

    MAPLINE map 1 1 6 3 "+"
    MAPCOUNT map "+" line_count

    IF line_count > 0 {
        CALL pass MAPLINE
    }
    ELSE {
        CALL fail MAPLINE
    }

    MAPFINDALL map "#" wall_positions
    LET wall_count = LEN wall_positions

    IF wall_count > 0 {
        CALL pass MAPFINDALL
    }
    ELSE {
        CALL fail MAPFINDALL
    }

    MAPREPLACE map "+" "."
    MAPCOUNT map "+" plus_left

    IF plus_left == 0 {
        CALL pass MAPREPLACE
    }
    ELSE {
        CALL fail MAPREPLACE
    }

    MAPCOPY map map_copy
    GETTILE map_copy 0 0 copied_tile

    IF copied_tile == "#" {
        CALL pass MAPCOPY
    }
    ELSE {
        CALL fail MAPCOPY
    }

    MAPFILL 4 3 "." stamp
    MAPBORDER stamp "*"
    MAPPASTE map stamp 1 1
    GETTILE map 1 1 pasted_tile

    IF pasted_tile == "*" {
        CALL pass MAPPASTE
    }
    ELSE {
        CALL fail MAPPASTE
    }

    VIEWPORT map 0 0 4 3 view
    LET view_h = LEN view

    IF view_h == 3 {
        CALL pass VIEWPORT_height
    }
    ELSE {
        CALL fail VIEWPORT_height
    }

    GETTILE view 0 0 view_tile

    IF view_tile == "#" {
        CALL pass VIEWPORT_content
    }
    ELSE {
        CALL fail VIEWPORT_content
    }

    SAVEMAP map "v3_test_map.txt"
    LOADMAP "v3_test_map.txt" loaded_map
    MAPSIZE loaded_map loaded_w loaded_h

    IF loaded_w == 8 {
        CALL pass SAVEMAP_LOADMAP_width
    }
    ELSE {
        CALL fail SAVEMAP_LOADMAP_width
    }

    IF loaded_h == 5 {
        CALL pass SAVEMAP_LOADMAP_height
    }
    ELSE {
        CALL fail SAVEMAP_LOADMAP_height
    }

    PRINT ""
    PRINT YELLOW "2) MENU SYSTEM"

    MENUCREATE main_menu
    MENUADD main_menu "Start Game"
    MENUADD main_menu "Options"
    MENUADD main_menu "Exit"
    MENUCOUNT main_menu menu_count

    IF menu_count == 3 {
        CALL pass MENUCREATE_MENUADD_MENUCOUNT
    }
    ELSE {
        CALL fail MENUCREATE_MENUADD_MENUCOUNT
    }

    MENUDRAW main_menu
    MENUSHOW main_menu menu_choice DEFAULT 2

    IF menu_choice == "Options" {
        CALL pass MENUSHOW_DEFAULT
    }
    ELSE {
        CALL fail MENUSHOW_DEFAULT
    }

    SELECTLIST [Easy,Normal,Hard] difficulty DEFAULT 3

    IF difficulty == "Hard" {
        CALL pass SELECTLIST_DEFAULT
    }
    ELSE {
        CALL fail SELECTLIST_DEFAULT
    }

    CONFIRM "Continue?" confirm_ok DEFAULT yes

    IF confirm_ok == true {
        CALL pass CONFIRM_DEFAULT
    }
    ELSE {
        CALL fail CONFIRM_DEFAULT
    }

    PROMPT "Player name" player_name DEFAULT "Agent"

    IF player_name == "Agent" {
        CALL pass PROMPT_DEFAULT
    }
    ELSE {
        CALL fail PROMPT_DEFAULT
    }

    MENUCLEAR main_menu
    MENUCOUNT main_menu menu_count_after_clear

    IF menu_count_after_clear == 0 {
        CALL pass MENUCLEAR
    }
    ELSE {
        CALL fail MENUCLEAR
    }

    PRINT ""
    PRINT YELLOW "3) EVENT SYSTEM"

    EVENTSET door_open false
    EVENTGET door_open door_value

    IF door_value == false {
        CALL pass EVENTSET_EVENTGET
    }
    ELSE {
        CALL fail EVENTSET_EVENTGET
    }

    EVENTEXISTS door_open door_exists

    IF door_exists == true {
        CALL pass EVENTEXISTS_true
    }
    ELSE {
        CALL fail EVENTEXISTS_true
    }

    EVENTONCE intro intro_first
    EVENTONCE intro intro_second

    IF intro_first == true {
        CALL pass EVENTONCE_first
    }
    ELSE {
        CALL fail EVENTONCE_first
    }

    IF intro_second == false {
        CALL pass EVENTONCE_second
    }
    ELSE {
        CALL fail EVENTONCE_second
    }

    TRIGGER boss_defeated
    EVENTGET boss_defeated boss_event

    IF boss_event == true {
        CALL pass TRIGGER_EVENTGET
    }
    ELSE {
        CALL fail TRIGGER_EVENTGET
    }

    ONTRIGGER boss_defeated mark_boss

    IF boss_mark == 1 {
        CALL pass ONTRIGGER
    }
    ELSE {
        CALL fail ONTRIGGER
    }

    EVENTCLEAR door_open
    EVENTEXISTS door_open door_exists_after_clear

    IF door_exists_after_clear == false {
        CALL pass EVENTCLEAR
    }
    ELSE {
        CALL fail EVENTCLEAR
    }

    PRINT ""
    PRINT GREEN "=============================="
    PRINT GREEN " V3 TEST RESULT"
    PRINT GREEN "=============================="

    PRINT "Passed:"
    PRINT %passed%

    PRINT "Failed:"
    PRINT %failed%

    IF failed == 0 {
        PRINT GREEN "ALL V3 TESTS PASSED"
    }
    ELSE {
        PRINT RED "SOME V3 TESTS FAILED"
    }
}

CALL main
