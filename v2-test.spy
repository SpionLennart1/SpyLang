# SpyLang v2.0 Game Engine Demo

CLS
PRINT GREEN "=============================="
PRINT GREEN " SPYLANG v2.0 GAME ENGINE DEMO"
PRINT GREEN "=============================="
VERSION

PRINT ""
PRINT YELLOW "OBJECTS:"
LET player = {name:"Agent",hp:100,gold:25}
PRINT player.name
PRINT player.hp
SET player.hp 80
OBJSET player level 2
OBJGET player level player_level
PRINT "Player level:"
PRINT %player_level%

PRINT ""
PRINT YELLOW "INVENTORY:"
LET inventory = [Potion]
ADDITEM inventory "Key"
HASITEM inventory "Key" has_key
PRINT "Has key:"
PRINT %has_key%

PRINT ""
PRINT YELLOW "MAP:"
LET map = [
"#######",
"#P..E.#",
"#..#..#",
"#.....#",
"#######"
]

DRAWMAP map

FINDPOS map "P" px py
FINDPOS map "E" ex ey

PRINT ""
PRINT "Player position:"
PRINT %px%
PRINT %py%

PRINT ""
PRINT YELLOW "MOVEPLAYER right:"
MOVEPLAYER map px py "d" moved
DRAWMAP map

PRINT "Moved:"
PRINT %moved%

GETTILE map ex ey enemy_tile
PRINT "Enemy tile:"
PRINT %enemy_tile%

DISTANCE px py ex ey dist
PRINT "Distance to enemy:"
PRINT %dist%

PRINT ""
PRINT YELLOW "AI PATH:"
AIPATH ex ey px py enemy_dir
PRINT %enemy_dir%

PRINT ""
PRINT YELLOW "AI / RANDOM GAME HELPERS:"
AICHANCE 25 crit
IF crit == true {
    PRINT RED "Critical chance worked!"
}
ELSE {
    PRINT "No crit."
}

AIWEIGHTED [Attack:70,Shield:20,Heal:10] enemy_move
PRINT "Enemy move:"
PRINT %enemy_move%

DICE 2 6 roll
PRINT "2d6 roll:"
PRINT %roll%

PRINT ""
PRINT YELLOW "SAVE SLOT:"
SAVESLOT 1 player
LOADSLOT 1 loaded_player
PRINT loaded_player.name
LISTSLOTS slots
PRINT "Slots:"
PRINT %slots%

PRINT ""
PRINT YELLOW "SCREEN:"
SCREENCLEAR
SCREENWRITE 0 0 "HP:"
SCREENWRITE 4 0 player.hp
SCREENWRITE 0 1 "Gold:"
SCREENWRITE 6 1 player.gold
SCREENRENDER

PRINT ""
PRINT YELLOW "TIMER:"
TIMERSTART game_timer
SLEEP 0.2
TIMERGET game_timer elapsed
PRINT "Elapsed:"
PRINT %elapsed%

PRINT ""
PRINT GREEN "v2.0 demo done!"
WAITKEY
